# Copy to .env for docker-compose.production.yml. Never commit real credentials.
GIT_LFS_DELTA_IMAGE=ghcr.io/tamedtornado/git-lfs-delta:v0.1.0-beta.2
GIT_LFS_DELTA_DATABASE_URL=postgres://git_lfs_delta_app:change-me@postgres.example/git_lfs_delta
GIT_LFS_DELTA_MIGRATOR_DATABASE_URL=postgres://git_lfs_delta_migrator:change-me@postgres.example/git_lfs_delta
GIT_LFS_DELTA_STORAGE_URL=s3://git-lfs-delta
GIT_LFS_DELTA_BASE_URL=https://lfs.example.com/
GIT_LFS_DELTA_FORGEJO_URL=https://forgejo.example.com/
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_REGION=us-east-1
AWS_ENDPOINT=https://s3.example.com
